    "Photographers_Caption_1" : {
      "comment" : "Shown in gray at the bottom of the Photographers page (1/4).",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "① This page lists all the photographers known to the app. The list shown can be filtered using the search bar."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "① Deze lijst bevat alle fotografen die de app momenteel kent. De lijst is filterbaar via het zoekveld (vergrootglas)."
          }
        }
      }
    },
    "Photographers_Caption_2" : {
      "comment" : "Shown in gray at the bottom of the Photographers page (2/4).",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "② The thumbnails can be scrolled horizontally. If you see more than one, the app associates the photographer with multiple clubs (today or in the past)."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "③ De “thumbnail“ foto's kunnen horizontaal verplaatst worden. Als een fotograaf bij meerdere clubs aangesloten is (of was) zijn er namelijk twee of meer “thumbnails“."
          }
        }
      }
    },
    "Photographers_Caption_3" : {
      "comment" : "Shown in gray at the bottom of the Photographers page (3/4).",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "③ Clicking on a thumbnail (or chevron) brings you to the image portfolio for that photographer/club combination. Clicking on the image (or circular icon) switches between portrait- and portfolio images - where available."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "② Klik op een foto-onderschrift om een portfolio bij die club te bekijken. Klik op de foto zelf om te schakelen tussen 2 alternatieve foto’s: een portretfoto en een portfoliofoto. Dit vereist dat er een portretfoto beschikbaar is (en is herkenbaar door aanwezigheid van een extra - rond - knopje)."
          }
        }
      }
    },
