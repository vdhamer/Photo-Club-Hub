        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "② You can unlock/lock a map's scrolling and panning features using the Lock icon."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "② Als het “slotje” open is, kan een kaart verplaatst of gezoomd worden."
          }
        }
      }
    },
    "Organizations_Caption_3" : {
      "comment" : "Shown in gray at the bottom of the Organizations page (3/3).",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "③ This list consists of two sublists. The first shows the photo clubs, the second shows photo museums. Individual sublists can be enabled/disabled in Preferences. The titel of the Organizations screen may then change to “Clubs” or “Museums”. "
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "③ Dit scherm kan twee soorten organisaties (Clubs en Musea) tonen. Welke getoond worden hangt af van keuzes onder Instellingen. Afhankelijk van deze keuzes is de titel van dit scherm “Organisaties”, “Clubs” of “Musea”."
          }
        }
      }
    },
