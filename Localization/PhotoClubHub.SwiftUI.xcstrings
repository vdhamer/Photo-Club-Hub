            "state" : "translated",
            "value" : "To see names here, please adapt the Search filter or enable additional categories on the Preferences page."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Deze lijst is leeg doordat de Zoek filter niets vindt in de gekozen ledencategorieën. Pas dus de Zoek filter aan of voeg categorieën toe (bij Instellingen)."
          }
        }
      }
    },
    "To see names here, please enable additional categories on the Preferences page." : {
